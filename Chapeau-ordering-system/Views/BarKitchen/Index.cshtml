@using Chapeau_ordering_system.ViewModels
@using Chapeau_ordering_system.Models.Enums
@model BarKitchenViewModel

@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@Model.PageTitle</h1>
        </div>

        <div class="col-md-4 text-end">
            <a asp-controller="BarKitchen" asp-action="Index" asp-route-viewMode="@Model.ViewModel" class="btn btn-primary">
                Refresh
            </a>
        </div>
    </div>

    <!-- View Mode Tabs -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <a asp-controller="BarKitchen" asp-action="Index" asp-route-viewMode="running" 
                   class="btn @(Model.ViewModel == "running" ? "btn-primary" : "btn-outline-primary")">
                    Running Orders
                </a>
                <a asp-controller="BarKitchen" asp-action="Index" asp-route-viewMode="finished" 
                   class="btn @(Model.ViewModel == "finished" ? "btn-primary" : "btn-outline-primary")">
                    Finished Today
                </a>
            </div>
        </div>
    </div>

    <!-- I show an error message if something went wrong -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @Model.ErrorMessage
        </div>
    }

    <!-- I show a confirmation message after changing a status -->
    @if (!string.IsNullOrEmpty(Model.ConfirmMessage))
    {
        <div class="alert alert-success" role="alert">
            @Model.ConfirmMessage
        </div>
    }

    <!-- I show this message when there are no orders -->
    @if (Model.Orders.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <strong>
                @if (Model.IsFinishedView)
                {
                    <text>No finished orders today</text>
                }
                else
                {
                    <text>No running orders</text>
                }
            </strong>
            - 
            @if (Model.IsFinishedView)
            {
                <text>There are currently no items marked as ready to be served.</text>
            }
            else
            {
                <text>There are currently no items waiting for preparation.</text>
            }
        </div>
    }
    else
    {
        <!-- I show the orders as cards -->
        <div class="row">
            @foreach (var order in Model.Orders)
            {
                var displayTime    = Model.IsFinishedView ? order.FinishedAt    : order.OrderTime;
                var waitingMinutes = Model.IsFinishedView ? order.MinutesSinceFinished : order.MinutesSinceOrder;

                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                Table @(order.Table?.TableNumber ?? "Unknown")
                            </h5>
                            @if (!Model.IsFinishedView)
                            {
                                <div class="btn-group btn-group-sm">
                                    <form asp-controller="BarKitchen" asp-action="StartOrder" method="post" style="display:inline;">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <button type="submit" class="btn btn-warning btn-sm">
                                            Start All
                                        </button>
                                    </form>
                                    <form asp-controller="BarKitchen" asp-action="MarkOrderReady" method="post" style="display:inline;">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            Ready All
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>

                        <div class="card-body">
                            <p>
                                <strong>@(Model.IsFinishedView ? "Finished Time:" : "Order Time:")</strong>
                                @displayTime.ToString("HH:mm")
                            </p>

                            <p>
                                <strong>@(Model.IsFinishedView ? "Finished:" : "Waiting Time:")</strong>
                                @waitingMinutes minutes
                            </p>

                            <p>
                                <strong>Items:</strong>
                                @order.OrderItems!.Count
                            </p>

                            <hr />

                            <!-- I show the order items with course grouping for food -->
                            @if (Model.MenuItemType == MenuItemType.Food)
                            {
                                <!-- I group food items by course -->
                                @foreach (var course in Enum.GetValues(typeof(CourseType)).Cast<CourseType>())
                                {
                                    var itemsInCourse = order.GetItemsByCourse(course);

                                    @if (itemsInCourse.Count > 0)
                                    {
                                        <h6 class="mt-3 mb-2">
                                            <strong>@course</strong>
                                        </h6>

                                        @if (!Model.IsFinishedView)
                                        {
                                            <div class="btn-group btn-group-sm mb-2">
                                                <form asp-controller="BarKitchen" asp-action="StartCourse" method="post" style="display:inline;">
                                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                                    <input type="hidden" name="courseType" value="@((int)course)" />
                                                    <button type="submit" class="btn btn-info btn-sm">
                                                        Start Course
                                                    </button>
                                                </form>
                                                <form asp-controller="BarKitchen" asp-action="MarkCourseReady" method="post" style="display:inline;">
                                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                                    <input type="hidden" name="courseType" value="@((int)course)" />
                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        Ready Course
                                                    </button>
                                                </form>
                                            </div>
                                        }

                                        @foreach (var item in itemsInCourse)
                                        {
                                            @await Html.PartialAsync("_OrderItemDisplay", item, new ViewDataDictionary(ViewData) { { "IsFinishedView", Model.IsFinishedView } })
                                        }
                                    }
                                }
                            }
                            else
                            {
                                <!-- I show drink items without course grouping -->
                                @foreach (var item in order.OrderItems)
                                {
                                    <div class="border rounded p-2 mb-2">
                                        <p class="mb-1">
                                            <strong>@item.Quantity x @(item.MenuItem?.Name ?? "Unknown item")</strong>
                                        </p>

                                        @if (!string.IsNullOrEmpty(item.Comment))
                                        {
                                            <p class="mb-1">
                                                <strong>Comment:</strong> @item.Comment
                                            </p>
                                        }

                                        <p class="mb-1">
                                            <strong>Status:</strong> @item.Status
                                        </p>

                                        @if (item.CanBeStarted)
                                        {
                                            <form asp-controller="BarKitchen" asp-action="StartItem" method="post">
                                                <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                                <button type="submit" class="btn btn-warning btn-sm">Start Item</button>
                                            </form>
                                        }
                                        else if (item.CanBeMarkedReady)
                                        {
                                            <form asp-controller="BarKitchen" asp-action="MarkItemReady" method="post">
                                                <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                                <button type="submit" class="btn btn-success btn-sm">Mark Item Ready</button>
                                            </form>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
