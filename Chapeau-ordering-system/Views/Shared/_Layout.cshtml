<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chapeau_ordering_system</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Chapeau_ordering_system.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Chapeau_ordering_system</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center">
                        @{
                            var employeeId   = Context.Session.GetInt32("EmployeeId");
                            var employeeName = Context.Session.GetString("EmployeeName");
                            var employeeRole = Context.Session.GetString("EmployeeRole");
                        }
                        @if (employeeId != null)
                        {
                            <ul class="navbar-nav me-3">
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="RestaurantOverview" asp-action="Index">Overview</a>
                                </li>
                                @if (employeeRole == "Waiter" || employeeRole == "Manager")
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown">Orders</a>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item" asp-controller="RestaurantOverview" asp-action="Index">Payment (select table from Overview)</a></li>
                                        </ul>
                                    </li>
                                }
                                @if (employeeRole == "Bar" || employeeRole == "Kitchen")
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="BarKitchen" asp-action="Index">@employeeRole</a>
                                    </li>
                                }
                                @if (employeeRole == "Manager")
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown">Management</a>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item" asp-controller="Management" asp-action="MenuItems">Menu Items</a></li>
                                            <li><a class="dropdown-item" asp-controller="Management" asp-action="Employees">Employees</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" asp-controller="Management" asp-action="FinancialOverview">Financial Overview</a></li>
                                        </ul>
                                    </li>
                                }
                            </ul>
                            <span class="me-3 text-muted small">
                                <strong>@employeeName</strong>
                                <span class="badge bg-secondary ms-1">@employeeRole</span>
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Log out</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Log in</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Chapeau_ordering_system - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
