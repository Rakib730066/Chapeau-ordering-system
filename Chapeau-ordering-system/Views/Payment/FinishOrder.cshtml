@model Chapeau_ordering_system.ViewModels.FinishOrderViewModel
@using Chapeau_ordering_system.Models.Enums

@{
    ViewData["Title"] = "Finish Order";
}

<div class="container mt-4">
    <h2>Finish Order — Table @Model.TableNumber</h2>

    <div class="card mb-3">
        <div class="card-body">
            <p class="mb-1"><strong>Total to pay:</strong> €@Model.TotalToPay.ToString("0.00")</p>
            <p class="mb-1 text-muted small">VAT 9%: €@Model.VatLow.ToString("0.00") &nbsp;·&nbsp; VAT 21%: €@Model.VatHigh.ToString("0.00")</p>
        </div>
    </div>

    <form asp-action="FinishOrder" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OrderId" />
        <input type="hidden" asp-for="TableId" />
        <input type="hidden" asp-for="TableNumber" />
        <input type="hidden" asp-for="TotalToPay" />
        <input type="hidden" asp-for="VatLow" />
        <input type="hidden" asp-for="VatHigh" />

        <div class="mb-3">
            <label asp-for="AmountPaid" class="form-label">Total amount paid (€)</label>
            <input asp-for="AmountPaid" type="number" step="0.01" min="0.01" class="form-control" />
            <span asp-validation-for="AmountPaid" class="text-danger"></span>
            <div class="form-text">
                Anything above the bill total of €@Model.TotalToPay.ToString("0.00") will be recorded as tip.
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="PaymentMethod" class="form-label">Payment method</label>
            <select asp-for="PaymentMethod" class="form-select"
                    asp-items="Html.GetEnumSelectList<PaymentMethod>()">
            </select>
            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Feedback" class="form-label">Guest feedback (optional)</label>
            <textarea asp-for="Feedback" class="form-control" rows="3"
                      placeholder="e.g. The food was wonderful"></textarea>
            <span asp-validation-for="Feedback" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Confirm payment</button>
        <a asp-action="ViewOrder" asp-route-tableId="@Model.TableId" class="btn btn-secondary">Cancel</a>
    </form>
</div>