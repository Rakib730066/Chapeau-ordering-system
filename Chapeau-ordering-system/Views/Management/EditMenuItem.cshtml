@model Chapeau_ordering_system.ViewModels.MenuItemFormViewModel
@using Chapeau_ordering_system.Models.Enums
@{
    ViewData["Title"] = "Edit Menu Item";
}

<div class="container mt-4" style="max-width:520px">
    <h4 class="fw-bold mb-3">Edit Menu Item</h4>

    <form asp-action="EditMenuItem" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="MenuItemId" type="hidden" />

        <div class="mb-2">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="row g-2 mb-2">
            <div class="col">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col">
                <label asp-for="Stock" class="form-label"></label>
                <input asp-for="Stock" type="number" class="form-control" />
                <span asp-validation-for="Stock" class="text-danger small"></span>
            </div>
        </div>
        <div class="row g-2 mb-2">
            <div class="col">
                <label asp-for="Type" class="form-label"></label>
                <select asp-for="Type" class="form-select"
                        asp-items="Html.GetEnumSelectList<MenuItemType>()"></select>
            </div>
            <div class="col">
                <label asp-for="Course" class="form-label"></label>
                <select asp-for="Course" class="form-select"
                        asp-items="Html.GetEnumSelectList<CourseType>()"></select>
            </div>
        </div>
        <div class="row g-2 mb-2">
            <div class="col">
                <label asp-for="Card" class="form-label"></label>
                <select asp-for="Card" class="form-select"
                        asp-items="Html.GetEnumSelectList<CardType>()"></select>
            </div>
            <div class="col">
                <label asp-for="VatRate" class="form-label">VAT Rate (0.09 or 0.21)</label>
                <input asp-for="VatRate" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="VatRate" class="text-danger small"></span>
            </div>
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label">Active</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="MenuItems" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
