@model List<Chapeau_ordering_system.Models.Employee>
@using Chapeau_ordering_system.Models.Enums
@{
    ViewData["Title"] = "Manage Employees";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">Employees</h4>
        <a asp-action="CreateEmployee" class="btn btn-primary btn-sm">+ Add Employee</a>
    </div>

    @if (TempData["ConfirmMessage"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show">@ok <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["ErrorMessage"] is string err)
    {
        <div class="alert alert-danger">@err</div>
    }

    <table class="table table-sm table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr class="@(!emp.IsActive ? "table-secondary text-muted" : "")">
                    <td>@emp.EmployeeId</td>
                    <td>@emp.FirstName @emp.LastName</td>
                    <td>@emp.Username</td>
                    <td>@emp.Email</td>
                    <td><span class="badge bg-secondary">@emp.Role</span></td>
                    <td>
                        @if (emp.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="EditEmployee" asp-route-id="@emp.EmployeeId"
                               class="btn btn-outline-secondary btn-sm">Edit</a>

                            <form asp-action="ToggleEmployeeActive" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@emp.EmployeeId" />
                                <input type="hidden" name="isActive" value="@(!emp.IsActive)" />
                                <button type="submit"
                                        class="btn btn-sm @(emp.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                    @(emp.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
