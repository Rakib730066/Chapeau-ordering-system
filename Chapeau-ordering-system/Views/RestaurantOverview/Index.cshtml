@model Chapeau_ordering_system.ViewModels.RestaurantOverviewViewModel
@using Chapeau_ordering_system.Models.Enums
@{
    ViewData["Title"] = "Restaurant Overview";
    var userRole = ViewData["EmployeeRole"]?.ToString();
    bool isWaiter = !string.IsNullOrEmpty(userRole) &&
                    userRole.Equals("Waiter", StringComparison.OrdinalIgnoreCase);
    var tables = Model.Tables
        .OrderBy(t => int.TryParse(t.TableNumber.Replace("T", ""), out int n) ? n : 0)
        .ToList();
}

<style>
    .item-status-badge {
        font-size: 0.65rem;
        padding: 2px 6px;
    }
    .order-item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 3px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 6px;
    }
    .order-item-row:last-child { border-bottom: none; }
    .item-name { font-size: 0.8rem; flex: 1; }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0 fw-bold">Restaurant Overview</h4>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small">
                Welcome, <strong>@ViewData["EmployeeName"]</strong>
                <span class="badge bg-secondary ms-1">@ViewData["EmployeeRole"]</span>
            </span>
            <form method="get" asp-action="Index">
                <button type="submit" class="btn btn-sm btn-outline-secondary">&#8635; Refresh</button>
            </form>
        </div>
    </div>

    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @err <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert-danger">@errMsg</div>
    }
    @if (TempData["ConfirmMessage"] is string confirmMsg)
    {
        <div class="alert alert-success">@confirmMsg</div>
    }

    <!-- Legend -->
    <div class="d-flex gap-3 mb-3 small">
        <span><span class="badge bg-success">Free</span></span>
        <span><span class="badge bg-danger">Occupied</span></span>
        <span><span class="badge bg-primary item-status-badge">Ordered</span></span>
        <span><span class="badge bg-warning text-dark item-status-badge">Being Prepared</span></span>
        <span><span class="badge bg-success item-status-badge">Ready to Serve</span></span>
        <span><span class="badge bg-secondary item-status-badge">Served</span></span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var table in tables)
        {
            var isOccupied = table.Status == TableStatus.Occupied;
            var tableOrders = Model.GetOrdersForTable(table.TableId).ToList();
            var hasOrders = tableOrders.Any();

            string headerClass = isOccupied ? "bg-danger text-white" : "bg-success text-white";
            string borderClass = isOccupied ? "border-danger" : "border-success";

            <div class="col">
                <div class="card h-100 @borderClass" style="border-width: 2px;">
                    <!-- Card header -->
                    <div class="card-header d-flex justify-content-between align-items-center py-2 @headerClass">
                        <strong>@table.TableNumber</strong>
                        <div class="d-flex align-items-center gap-2">
                            @if (table.OccupiedSince.HasValue)
                            {
                                int mins = (int)(DateTime.Now - table.OccupiedSince.Value).TotalMinutes;
                                <small>@mins min</small>
                            }
                            <span class="badge bg-light text-dark">@table.Status</span>
                        </div>
                    </div>

                    <div class="card-body p-2">
                        <div class="small text-muted mb-1">Seats: @table.NumberOfSeats</div>

                        @if (isOccupied && hasOrders)
                        {
                            <!-- R3: show all order items with their statuses -->
                            @foreach (var order in tableOrders)
                            {
                                @foreach (var item in order.OrderItems.Where(i => i.Status != OrderItemStatus.Cancelled))
                                {
                                    string badgeClass = item.Status switch {
                                        OrderItemStatus.Ordered         => "bg-primary",
                                        OrderItemStatus.BeingPrepared   => "bg-warning text-dark",
                                        OrderItemStatus.ReadyToBeServed => "bg-success",
                                        OrderItemStatus.Served          => "bg-secondary",
                                        _                               => "bg-secondary"
                                    };

                                    <div class="order-item-row">
                                        <span class="item-name">
                                            @item.Quantity&times; @item.MenuItem?.Name
                                        </span>
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="badge @badgeClass item-status-badge">@item.Status</span>
                                            @if (item.Status == OrderItemStatus.ReadyToBeServed)
                                            {
                                                <form method="post" asp-action="MarkServed" asp-controller="RestaurantOverview">
                                                    <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                                    <button type="submit"
                                                            class="btn btn-outline-success py-0 px-1"
                                                            style="font-size:0.65rem;">
                                                        Serve ✓
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        }
                        else if (isOccupied)
                        {
                            <p class="text-muted small mb-0">No items ordered yet.</p>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Table is free.</p>
                        }
                    </div>

                    <!-- Action buttons -->
                    <div class="card-footer bg-transparent pt-1 pb-2 px-2 d-flex flex-column gap-1">
                        @if (isWaiter)
                        {
                            if (table.IsFree)
                            {
                                <form asp-controller="Order" asp-action="StartOrder" method="post">
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <button type="submit" class="btn btn-sm btn-primary w-100">Start Order</button>
                                </form>
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="1" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">Mark Occupied</button>
                                </form>
                            }
                            else if (isOccupied)
                            {
                                if (table.CurrentOrderId.HasValue)
                                {
                                    <form asp-controller="Order" asp-action="LoadOrder" method="post">
                                        <input type="hidden" name="tableId" value="@table.TableId" />
                                        <button type="submit" class="btn btn-sm btn-warning w-100">Load Order</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Order" asp-action="StartOrder" method="post">
                                        <input type="hidden" name="tableId" value="@table.TableId" />
                                        <button type="submit" class="btn btn-sm btn-primary w-100">Start Order</button>
                                    </form>
                                }
                                @if (hasOrders)
                                {
                                    <a asp-controller="Payment" asp-action="ViewOrder"
                                       asp-route-tableId="@table.TableId"
                                       class="btn btn-sm btn-success w-100">Pay</a>
                                }
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="0" />
                                    <button type="submit" class="btn btn-sm btn-outline-success w-100">Mark Free</button>
                                </form>
                            }
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary w-100" disabled>Login as Waiter to manage</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
