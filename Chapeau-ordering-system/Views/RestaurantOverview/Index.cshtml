@model Chapeau_ordering_system.ViewModels.RestaurantOverviewViewModel
@using Chapeau_ordering_system.Models.Enums

@{
    ViewData["Title"] = "Restaurant Overview";
    var tables = Model.Tables.OrderBy(t => t.TableNumber).ToList();
}

@functions {
    static string BadgeClass(TableStatus status) => status switch
    {
        TableStatus.Free => "bg-success",
        TableStatus.Occupied => "bg-danger",
        TableStatus.Reserved => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    static string BorderClass(TableStatus status) => status switch
    {
        TableStatus.Free => "border-success",
        TableStatus.Occupied => "border-danger",
        _ => "border-secondary"
    };

    static string ItemBadgeClass(OrderItemStatus status) => status switch
    {
        OrderItemStatus.Ordered => "bg-primary",
        OrderItemStatus.BeingPrepared => "bg-warning text-dark",
        OrderItemStatus.ReadyToBeServed => "bg-success",
        OrderItemStatus.Served => "bg-secondary",
        _ => "bg-secondary"
    };
}

<div class="container mt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Restaurant Overview</h2>
        <span>
            Welcome, <strong>@ViewData["EmployeeName"]</strong>
            <span class="badge bg-secondary ms-1">@ViewData["EmployeeRole"]</span>
        </span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Tables</h5>
        <form method="get" asp-action="Index">
            <button type="submit" class="btn btn-sm btn-outline-primary">Refresh</button>
        </form>
    </div>

    <div style="display:grid; grid-template-columns: repeat(2, 1fr); gap:16px;">
        @foreach (var t in tables)
        {
            var orders = Model.GetOrdersForTable(t.TableId).ToList();

            <div class="card border @BorderClass(t.Status)">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <strong>Table @t.TableNumber</strong>
                    <span class="badge @BadgeClass(t.Status)">@t.Status</span>
                </div>
                <div class="card-body p-2">
                    <div class="small text-muted">Seats: @t.NumberOfSeats</div>
                    @if (t.OccupiedSince.HasValue)
                    {
                        <div class="small text-muted">Since: @t.OccupiedSince.Value.ToShortTimeString()</div>
                    }
                    <div class="mt-2">
                        @if (t.Status == TableStatus.Free)
                        {
                            <form method="post" asp-action="ChangeStatus" asp-controller="RestaurantOverview">
                                <input type="hidden" name="tableId" value="@t.TableId" />
                                <input type="hidden" name="newStatus" value="1" />
                                <button type="submit" class="btn btn-sm btn-danger w-100">Mark as Occupied</button>
                            </form>
                        }
                        else if (t.Status == TableStatus.Occupied)
                        {
                            <form method="post" asp-action="ChangeStatus" asp-controller="RestaurantOverview">
                                <input type="hidden" name="tableId" value="@t.TableId" />
                                <input type="hidden" name="newStatus" value="0" />
                                <button type="submit" class="btn btn-sm btn-success w-100">Mark as Free</button>
                            </form>
                        }
                    </div>


                    @if (orders.Any())
                    {
                        <hr class="my-2">
                        @foreach (var order in orders)
                        {
                            @foreach (var item in order.OrderItems)
                            {
                              <div class="d-flex justify-content-between align-items-center py-1">
    <span class="small">@item.Quantity&times; @item.MenuItem?.Name</span>
    <div class="d-flex align-items-center gap-1">
        <span class="badge @ItemBadgeClass(item.Status)">@item.Status</span>
        @if (item.Status == OrderItemStatus.ReadyToBeServed)
        {
            <form method="post" asp-action="MarkServed" asp-controller="RestaurantOverview">
                <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                <button type="submit" class="btn btn-sm btn-outline-success py-0 px-1" style="font-size:0.7rem;">Serve</button>
            </form>
        }
    </div>
</div>

                            }
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>
