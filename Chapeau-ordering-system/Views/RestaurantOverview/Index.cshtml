@model Chapeau_ordering_system.ViewModels.RestaurantOverviewViewModel
@using Chapeau_ordering_system.Models.Enums

@{
    ViewData["Title"] = "Restaurant Overview";
}

@* Fix 2: Auto-refresh every 30 seconds *@
<meta http-equiv="refresh" content="30">

<style>
    .item-status-badge { font-size: 0.65rem; padding: 2px 6px; }
    .order-item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 3px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 6px;
    }
    .order-item-row:last-child { border-bottom: none; }
    .item-name { font-size: 0.8rem; flex: 1; }
    .long-wait-pulse { animation: pulse 1.5s infinite; }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.6; }
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0 fw-bold">Restaurant Overview</h4>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small">
                Welcome, <strong>@Model.EmployeeName</strong>
                <span class="badge bg-secondary ms-1">@Model.EmployeeRole</span>
            </span>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">&#8635; Refresh</a>
        </div>
    </div>

    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @err <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @errMsg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ConfirmMessage"] is string confirmMsg)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @confirmMsg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Legend *@
    <div class="d-flex flex-wrap gap-3 mb-3 small">
        <span><span class="badge bg-success">Free</span></span>
        <span><span class="badge bg-danger">Occupied</span></span>
        <span><span class="badge bg-warning text-dark">Reserved</span></span>
        <span><span class="badge bg-info text-dark">Cleaning</span></span>
        <span><span class="badge bg-warning text-dark">&#9888; &gt;90 min wait</span></span>
        <span class="ms-3 text-muted">Items:</span>
        <span><span class="badge bg-primary item-status-badge">Ordered</span></span>
        <span><span class="badge bg-warning text-dark item-status-badge">Being Prepared</span></span>
        <span><span class="badge bg-success item-status-badge">Ready to Serve</span></span>
        <span><span class="badge bg-secondary item-status-badge">Served</span></span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var table in Model.Tables)
        {
            var tableOrders = Model.GetOrdersForTable(table.TableId).ToList();
            var hasOrders   = tableOrders.Any();

            <div class="col">
                <div class="card h-100 @table.CardBorderClass" style="border-width: 2px;">

                    @* Card header *@
                    <div class="card-header d-flex justify-content-between align-items-center py-2 @table.CardHeaderClass">
                        <div>
                            <strong>@table.TableNumber</strong>
                            @* Fix 5: Show area if available *@
                            @if (!string.IsNullOrWhiteSpace(table.Area))
                            {
                                <span class="ms-1 small opacity-75">(@table.Area)</span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            @* Fix 3: Long wait warning *@
                            @if (table.IsLongWait)
                            {
                                <span class="long-wait-pulse fw-bold" style="font-size:.75rem">&#9888; @table.MinutesSinceOccupied min</span>
                            }
                            else if (table.OccupiedSince.HasValue)
                            {
                                <small>@table.MinutesSinceOccupied min</small>
                            }
                            <span class="badge bg-light text-dark">@table.Status</span>
                        </div>
                    </div>

                    <div class="card-body p-2">
                        <div class="small text-muted mb-1">
                            Seats: @table.NumberOfSeats
                        </div>

                        @if (table.IsOccupied && hasOrders)
                        {
                            @foreach (var order in tableOrders)
                            {
                                @foreach (var item in order.ActiveItems)
                                {
                                    <div class="order-item-row">
                                        <span class="item-name">@item.Quantity&times; @item.MenuItem?.Name</span>
                                        <div class="d-flex align-items-center gap-1">
                                            @* Fix 4: use model property instead of switch in view *@
                                            <span class="badge @item.StatusBadgeClass item-status-badge">@item.Status</span>
                                            @if (item.CanBeServed)
                                            {
                                                <form method="post" asp-action="MarkServed" asp-controller="RestaurantOverview">
                                                    <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                                    <button type="submit" class="btn btn-outline-success py-0 px-1" style="font-size:0.65rem;">
                                                        Serve ✓
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        }
                        else if (table.IsOccupied)
                        {
                            <p class="text-muted small mb-0">No items ordered yet.</p>
                        }
                        else if (table.IsReserved)
                        {
                            <p class="text-muted small mb-0">
                                Reserved
                                @if (!string.IsNullOrWhiteSpace(table.ReservationName))
                                {
                                    <span>for <strong>@table.ReservationName</strong></span>
                                }
                            </p>
                        }
                        else if (table.IsCleaning)
                        {
                            <p class="text-muted small mb-0">Being cleaned.</p>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Table is free.</p>
                        }
                    </div>

                    @* Action buttons — Fix 1: Reserved & Cleaning statuses added *@
                    @if (Model.IsWaiter)
                    {
                        <div class="card-footer bg-transparent pt-1 pb-2 px-2 d-flex flex-column gap-1">
                            @if (table.IsFree)
                            {
                                <form asp-controller="Order" asp-action="StartOrder" method="post">
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <button type="submit" class="btn btn-sm btn-primary w-100">Start Order</button>
                                </form>
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="@((int)TableStatus.Reserved)" />
                                    <input type="text" name="reservationName" placeholder="Guest name (optional)"
                                           class="form-control form-control-sm mb-1" maxlength="100" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning w-100">Mark Reserved</button>
                                </form>
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="@((int)TableStatus.Occupied)" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">Mark Occupied</button>
                                </form>
                            }
                            else if (table.IsOccupied)
                            {
                                @if (table.CurrentOrderId.HasValue)
                                {
                                    <form asp-controller="Order" asp-action="LoadOrder" method="post">
                                        <input type="hidden" name="tableId" value="@table.TableId" />
                                        <button type="submit" class="btn btn-sm btn-warning w-100">Load Order</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Order" asp-action="StartOrder" method="post">
                                        <input type="hidden" name="tableId" value="@table.TableId" />
                                        <button type="submit" class="btn btn-sm btn-primary w-100">Start Order</button>
                                    </form>
                                }
                                @if (hasOrders)
                                {
                                    <a asp-controller="Payment" asp-action="ViewOrder"
                                       asp-route-tableId="@table.TableId"
                                       class="btn btn-sm btn-success w-100">Pay</a>
                                }
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="@((int)TableStatus.Cleaning)" />
                                    <button type="submit" class="btn btn-sm btn-outline-info w-100">Mark Cleaning</button>
                                </form>
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="@((int)TableStatus.Free)" />
                                    <button type="submit" class="btn btn-sm btn-outline-success w-100">Mark Free</button>
                                </form>
                            }
                            else if (table.IsReserved)
                            {
                                <form asp-controller="Order" asp-action="StartOrder" method="post">
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <button type="submit" class="btn btn-sm btn-primary w-100">Start Order</button>
                                </form>
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="@((int)TableStatus.Free)" />
                                    <button type="submit" class="btn btn-sm btn-outline-success w-100">Mark Free</button>
                                </form>
                            }
                            else if (table.IsCleaning)
                            {
                                <form asp-controller="RestaurantOverview" asp-action="ChangeStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tableId" value="@table.TableId" />
                                    <input type="hidden" name="newStatus" value="@((int)TableStatus.Free)" />
                                    <button type="submit" class="btn btn-sm btn-outline-success w-100">Mark Free</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
