@{
    ViewData["Title"] = "Restaurant Overview";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Restaurant Overview</h2>
        <div class="d-flex align-items-center gap-3">
            <span>
                Welcome, <strong>@ViewData["EmployeeName"]</strong>
                <span class="badge bg-secondary ms-1">@ViewData["EmployeeRole"]</span>
            </span>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                Log Out
            </a>
        </div>
    </div>

    <div class="alert alert-info">
            You are logged in as
        <strong>@ViewData["EmployeeRole"]</strong>
    </div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-center p-4 border-secondary">
                <h5 class="text-muted">Tables</h5>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center p-4 border-secondary">
                <h5 class="text-muted">Active Orders</h5>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center p-4 border-secondary">
                <h5 class="text-muted">Kitchen / Bar</h5>
            </div>
        </div>
    </div>

</div>